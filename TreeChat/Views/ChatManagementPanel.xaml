<UserControl x:Class="TreeChat.Views.ChatManagementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TreeChat.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel  Margin="0,10,0,10">

        <Button Content="新聊天" Command="{Binding CreateNewChat}"/>

        <ListBox Grid.Row="1"
             ItemsSource="{Binding ChatList}"
             FontSize="14"
             SelectedItem="{Binding SelectedChat, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding TreeTitle}"
                           Margin="5,2"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</UserControl>
