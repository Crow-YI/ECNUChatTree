<Window x:Class="TreeChat.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TreeChat.ViewModels"
        xmlns:views="clr-namespace:TreeChat.Views"
        xmlns:converters="clr-namespace:TreeChat.Converters"
        Title="树形AI聊天工具" Height="600" Width="1000">

    <Window.Resources>
        <converters:BooleanNegationConverter x:Key="BooleanNegationConverter"/>
    </Window.Resources>
    
    <Grid Background="Transparent">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="600"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0"
                    Margin="0,10,0,10">

            <Button Content="新聊天" Command="{Binding CreateNewTree}"/>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding ChatTreeList}"
                     FontSize="14"
                     SelectedItem="{Binding SelectedChatTree, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding TreeTitle}"
                                   Margin="5,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <Border Grid.Row="0" Grid.Column="1" 
                Background="#01FFFFFF"
                BorderBrush="Gray" BorderThickness="0,0,0,0">
            <views:TreeVisualizationView x:Name="treeView"
                                        SelectedNode="{Binding SelectedNode, Mode=TwoWay}"/>
        </Border>

        <Grid Grid.Row="0" Grid.Column="2"
              Margin="10,10">
            <Grid.RowDefinitions>
                <!-- 上部分占满剩余空间，下部分自适应高度 -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 上部分：信息展示区域 -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
                <StackPanel VerticalAlignment="Top">
                    <!-- 第一条信息 -->
                    <StackPanel>
                        <TextBlock Text="信息1" 
                                   FontSize="12" 
                                   Foreground="#666666"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding UserInformation}" 
                                   FontSize="14" 
                                   Foreground="#333333"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- 第二条信息 -->
                    <StackPanel>
                        <TextBlock Text="信息2" 
                                   FontSize="12" 
                                   Foreground="#666666"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding AIReply}" 
                                   FontSize="14" 
                                   Foreground="#333333"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 下部分：聊天输入区域 -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,10,0,0"
                    Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- 输入框占大部分空间，按钮固定宽度 -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- 文本输入框 -->
                    <TextBox Grid.Column="0"
                             FontSize="14"
                             Text="{Binding InputMessage}"
                             Padding="8"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="60"/>

                        <!-- 发送按钮 -->
                        <Button Grid.Column="1"
                                Content="发送"
                                Command="{Binding SendMessage}"
                                IsEnabled="{Binding IsSending, Converter={StaticResource BooleanNegationConverter}}"
                                Margin="8,0,0,0"
                                Background="#0078D7"
                                Foreground="White"
                                BorderThickness="0">
                            <!-- 按钮hover效果 -->
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#005A9E"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#CCCCCC"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>